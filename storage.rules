rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos — owner can write, anyone can read (for shared pages)
    match /profiles/{doctorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == doctorId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /dev_profiles/{doctorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == doctorId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Prod: cases files — only the doctor who owns the case path
    match /cases/{doctorId}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == doctorId;
      allow write: if request.auth != null
                   && request.auth.uid == doctorId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }

    // Dev: dev_cases files — same rules, prefixed path
    match /dev_cases/{doctorId}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == doctorId;
      allow write: if request.auth != null
                   && request.auth.uid == doctorId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
  }
}
