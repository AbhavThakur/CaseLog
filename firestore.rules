rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    // Checks both prod and dev collections
    function isAdmin() {
      return request.auth != null
        && (
          (exists(/databases/$(database)/documents/doctors/$(request.auth.uid))
           && get(/databases/$(database)/documents/doctors/$(request.auth.uid)).data.isAdmin == true)
          ||
          (exists(/databases/$(database)/documents/dev_doctors/$(request.auth.uid))
           && get(/databases/$(database)/documents/dev_doctors/$(request.auth.uid)).data.isAdmin == true)
        );
    }

    function isDevAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/dev_doctors/$(request.auth.uid))
        && get(/databases/$(database)/documents/dev_doctors/$(request.auth.uid)).data.isAdmin == true;
    }

    function isProdAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/doctors/$(request.auth.uid))
        && get(/databases/$(database)/documents/doctors/$(request.auth.uid)).data.isAdmin == true;
    }

    // ─── PROD collections ───

    // Counter document
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    // App config
    match /config/{configId} {
      allow read: if request.auth != null;
      allow write: if isProdAdmin();
    }

    // Doctor profiles
    match /doctors/{doctorId} {
      allow read: if request.auth != null
        && (request.auth.uid == doctorId || isProdAdmin());
      allow create: if request.auth != null && request.auth.uid == doctorId;
      allow update: if request.auth != null
        && (request.auth.uid == doctorId || isProdAdmin());
      allow list: if isProdAdmin();

      match /cases/{caseId} {
        allow read, write: if request.auth != null && request.auth.uid == doctorId;
        match /timeline/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == doctorId;
        }
        match /vitals/{vitalId} {
          allow read, write: if request.auth != null && request.auth.uid == doctorId;
        }
      }

      match /reminders/{reminderId} {
        allow read, write: if request.auth != null && request.auth.uid == doctorId;
      }
    }

    // ─── DEV collections (dev_ prefix) ───

    match /dev_counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    match /dev_config/{configId} {
      allow read: if request.auth != null;
      allow write: if isDevAdmin();
    }

    match /dev_doctors/{doctorId} {
      allow read: if request.auth != null
        && (request.auth.uid == doctorId || isDevAdmin());
      allow create: if request.auth != null && request.auth.uid == doctorId;
      allow update: if request.auth != null
        && (request.auth.uid == doctorId || isDevAdmin());
      allow list: if isDevAdmin();

      match /cases/{caseId} {
        allow read, write: if request.auth != null && request.auth.uid == doctorId;
        match /timeline/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == doctorId;
        }
        match /vitals/{vitalId} {
          allow read, write: if request.auth != null && request.auth.uid == doctorId;
        }
      }

      match /reminders/{reminderId} {
        allow read, write: if request.auth != null && request.auth.uid == doctorId;
      }
    }
  }
}
